// ============================================================
// changelogs（更新履歴）
//
// トップページの更新履歴セクションに表示するデータを管理するテーブル。
// is_published=1 のレコードを最新順で N 件取得して表示する。
// 対応ページ: /（トップページ）
// ============================================================

Table changelogs {
  id           int          [pk, increment, not null, note: 'ID']
  title        varchar(255) [not null, note: '更新タイトル']
  body         text         [null, note: '更新内容の詳細。Markdown可。']
  changed_at   date         [not null, note: '更新日']
  is_published tinyint(1)   [not null, default: 0, note: '公開フラグ（0:非公開 / 1:公開）']
  created_at   timestamp    [not null, default: `CURRENT_TIMESTAMP`]
  updated_at   timestamp    [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    changed_at   [name: 'idx_changed_at']
    is_published [name: 'idx_is_published']
  }

  Note: 'トップページ（/）の更新履歴セクションで使用する。最新N件を表示。'
}

