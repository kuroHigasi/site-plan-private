// ============================================================
// youtube_channel_settings（YouTubeチャンネル設定）
//
// YouTube ページ（/works/youtube/）の「チャンネル概要」セクションに
// 表示する情報を管理する singleton テーブル（行は常に 1 件）。
// 対応ページ：YouTube（/works/youtube/）
// ============================================================

Table youtube_channel_settings {
  id          int          [pk, not null, note: 'ID（固定値 1 のみ）', check: `id = 1`]
  overview    text         [not null, note: 'チャンネルの概要']
  channel_url varchar(255) [null, note: 'YouTube チャンネル URL']
  created_at  timestamp    [not null, default: `CURRENT_TIMESTAMP`]
  updated_at  timestamp    [not null, default: `CURRENT_TIMESTAMP`]

  Note: '''
  P006-04（YouTube）のチャンネル概要セクションで使用する singleton テーブル。

  - 行は常に 1 件（id = 1 固定）。AUTO_INCREMENT は付与しない。
  - 初期データはマイグレーションの seed で 1 行投入する想定。
  - 公開 API（youtube-channel.php）は本行を単件で返却する。
  '''
}
