// ============================================================
// qualifications（資格マスタ）
//
// 資格データを管理するマスタテーブル。
// 本マスタデータで公開/非公開を制御はせず、参照元で判断する。
// 対応ページ：取得資格一覧（/certifications/list/）、現在学習中の資格（/certifications/current/）
// ============================================================

Enum qualification_type {
  it [note: 'IT']
  design [note: 'デザイン']
  math [note: '数学']
  language [note: '言語']
  other [note: 'その他']
}

Table qualifications {
  id           int          [pk, increment, not null, note: 'ID']
  qualification_name         varchar(255) [not null, note: '資格名称']
  overview     text         [null, note: '資格の概要']
  category     qualification_type [not null, note: '資格種別']
  created_at   timestamp    [not null, default: `CURRENT_TIMESTAMP`]
  updated_at   timestamp    [not null, default: `CURRENT_TIMESTAMP`]

  indexes {
    category [name: 'idx_category']
  }

  Note: '資格情報の基盤となるマスタデータ'
}
